{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "uds-grafana-config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "domain": { "type": "string" },
        "adminDomain": { "type": "string" },
        "postgresql": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "host": { "type": "string" },
            "database": { "type": "string" },
            "user": { "type": "string" },
            "password": { "type": "string" },
            "ssl_mode": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "egressCidr": { "type": "string" }
          }
        }
      }
    },
    "grafana": { "type": "object" }
  }
}
