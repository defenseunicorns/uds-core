{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "pepr": { "type": "object" },
    "uds-operator-config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cluster": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "expose": {
              "type": "object",
              "properties": {
                "domain": { "type": "string" },
                "adminDomain": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "istiod": { "type": "object" },
    "uds-istio-config-admin": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "domain": { "type": "string" },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cert": { "type": "string" },
            "key": { "type": "string" },
            "supportTLSV1_2": { "type": "boolean" }
          }
        }
      }
    },
    "uds-istio-config-tenant": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "domain": { "type": "string" },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cert": { "type": "string" },
            "key": { "type": "string" },
            "supportTLSV1_2": { "type": "boolean" }
          }
        }
      }
    },
    "tenant-gateway": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "service": { "type": "object" }
      }
    }
  }
}
