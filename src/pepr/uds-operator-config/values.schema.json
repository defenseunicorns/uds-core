{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "AUTHSERVICE_REDIS_URI": {
          "type": "string",
          "description": "Redis URI for the auth service."
        },
        "KEYCLOAK_CLIENT_MODE": {
          "type": "string",
          "enum": ["AUTO", "CLIENT_SECRET", "SIGNED_JWT"],
          "description": "Authentication mode for the UDS Operator Keycloak client. AUTO tries signed JWT first, then falls back to client secret."
        },
        "ALLOW_PUBLIC_CLIENTS": {
          "type": ["boolean", "string"],
          "description": "When true, the UDS Operator admits SSO clients with publicClient: true that use flows beyond OAuth 2.0 Device Authorization Grant (PKCE S256 required). Defaults to false."
        }
      }
    },
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attributes": {
          "type": "object",
          "properties": {
            "clusterName": { "type": "string", "description": "Name of the cluster." },
            "clusterTags": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Tags for the cluster."
            }
          }
        },
        "caBundle": {
          "type": "object",
          "properties": {
            "certs": {
              "type": "string",
              "description": "Contents of user provided CA bundle certificates."
            },
            "includeDoDCerts": {
              "type": ["boolean", "string"],
              "description": "Include DoD CA certificates in the bundle."
            },
            "includePublicCerts": {
              "type": ["boolean", "string"],
              "description": "Include public CA certificates in the bundle."
            }
          }
        },
        "expose": {
          "type": "object",
          "properties": {
            "domain": { "type": "string", "description": "Domain for cluster exposure." },
            "adminDomain": {
              "type": "string",
              "description": "Admin domain for cluster exposure."
            }
          }
        },
        "policy": {
          "type": "object",
          "properties": {
            "allowAllNsExemptions": {
              "type": ["boolean", "string"],
              "description": "Allow all namespace exemptions."
            }
          }
        },
        "networking": {
          "type": "object",
          "properties": {
            "kubeApiCIDR": {
              "type": "string",
              "description": "CIDR for Kubernetes API server."
            },
            "kubeNodeCIDRs": {
              "type": "array",
              "items": { "type": "string" },
              "description": "List of CIDRs for Kubernetes nodes."
            }
          }
        }
      }
    }
  }
}
