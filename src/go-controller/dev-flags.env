# Feature flags for the UDS operator reconcile flow.
# Set a flag to "false" to disable that phase in Pepr (Go controller handles it instead).
# All default to "true" (Pepr handles everything).
#
# Dev workflow: edit flags here, then run:
#   uds run -f src/go-controller/tasks.yaml update-pepr      # apply to Pepr watcher
#   uds run -f src/go-controller/tasks.yaml update-controller # rebuild Go controller
UDS_OPERATOR_NETWORK_POLICIES_ENABLED=false
UDS_OPERATOR_AUTHORIZATION_POLICIES_ENABLED=false
UDS_OPERATOR_ISTIO_INJECTION_ENABLED=false
UDS_OPERATOR_ISTIO_INGRESS_ENABLED=false
UDS_OPERATOR_ISTIO_EGRESS_ENABLED=false
UDS_OPERATOR_SSO_ENABLED=false
UDS_OPERATOR_POD_MONITORS_ENABLED=false
UDS_OPERATOR_SERVICE_MONITORS_ENABLED=false
UDS_OPERATOR_UPTIME_PROBES_ENABLED=false
UDS_OPERATOR_CA_BUNDLE_ENABLED=false
